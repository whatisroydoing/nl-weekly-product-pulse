# IndMoney Weekly Product Pulse — Environment Variables
# Copy this file to .env and fill in your values.

# Google Gemini (clustering)
GEMINI_API_KEY=your_gemini_api_key_here

# xAI Grok (summary/action points)
GROK_API_KEY=your_grok_api_key_here

# OpenAI (clustering + pulse generation)
OPENAI_API_KEY=your_openai_api_key_here

# Email Toggle
EMAIL_MODE=API
GMAIL_API_AUTH_MODE=OAUTH2

# Gmail API Credentials (OAuth2)
GMAIL_USER=your_email@gmail.com
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token

# Gmail SMTP (only if EMAIL_MODE=SMTP)
# GMAIL_APP_PASSWORD=your_app_password_here

# Google Docs API (Fee Explainer)
# Local: use a file path. Production: paste the full JSON content.
GOOGLE_SERVICE_ACCOUNT_JSON=./docs/google-service-account.json
GOOGLE_DOC_ID=your_google_doc_id

# CORS — set to your frontend URL in production
ALLOWED_ORIGINS=*
