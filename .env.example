# IndMoney Weekly Product Pulse — Environment Variables

# Google Gemini (clustering)
GEMINI_API_KEY=your_gemini_api_key_here

# xAI Grok (summary/action points)
GROK_API_KEY=your_grok_api_key_here

# OpenAI (clustering)
OPENAI_API_KEY=your_openai_api_key_here

# Gmail — SMTP send (App Password method)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# SMTP (alternative to Gmail)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password_here

# Google Docs API (Fee Explainer append)
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
GOOGLE_DOC_ID=your_google_doc_id_here

# Security
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
